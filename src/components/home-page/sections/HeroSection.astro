---
import SectionLayout from "./SectionLayout.astro";

interface Props {
  tagline?: string;
  title?: string;
  description?: string;
  primaryButtonText?: string;
  primaryButtonTarget?: string;
  secondaryButtonText?: string;
  secondaryButtonTarget?: string;
}

const {
  tagline = "Astro Static Site",
  title = "가볍고 빠른\n정적 랜딩 페이지",
  description = "Astro로 만든 단일 페이지 예제입니다. 스크롤이 한 번 발생하면\n다음 또는 이전 섹션으로 한 번에 이동합니다.",
  primaryButtonText = "소개 보기",
  primaryButtonTarget = "#about",
  secondaryButtonText = "문의하기",
  secondaryButtonTarget = "#contact",
} = Astro.props;
---

<SectionLayout
  sectionId="home"
  sectionName="home"
  tagline={tagline}
  title={title}
  titleTag="h1"
  sectionClass="hero"
>
  <p class="description">
    {description}
  </p>

  <div class="actions">
    <a
      class="button"
      href={primaryButtonTarget}
      data-target={primaryButtonTarget.slice(1)}
    >
      {primaryButtonText}
    </a>
    <a
      class="button secondary"
      href={secondaryButtonTarget}
      data-target={secondaryButtonTarget.slice(1)}
    >
      {secondaryButtonText}
    </a>
  </div>
</SectionLayout>

<style>
  :global(.hero h1) {
    max-width: 760px;
    font-size: clamp(48px, 8vw, 88px);
  }

  .description {
    max-width: 660px;
    font-size: 18px;
  }

  .actions {
    display: flex;
    gap: 12px;
    margin-top: 32px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;

    background: #2563eb;
    color: white;
    font-weight: 700;

    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .button:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px rgba(37, 99, 235, 0.28);
  }

  .button.secondary {
    background: #e8eefc;
    color: #2563eb;
  }

  @media (max-width: 720px) {
    .actions {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
