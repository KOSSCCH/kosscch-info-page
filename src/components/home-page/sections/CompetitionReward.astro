---
import SectionLayout from "./SectionLayout.astro";

interface Props {
	tagline?: string;
	sectionId?: string;
	sectionName?: string;
	pretitle?: string;
	titleLine?: string;
	subtitle?: string;
	sectionClass?: string;
}

const {
	sectionId = "competition",
	sectionName = "competition",
	sectionClass = "",
} = Astro.props;
---

<SectionLayout
	sectionId={sectionId}
	sectionName={sectionName}
	sectionClass={`competition-info ${sectionClass}`.trim()}
>
	<div class="award-content">
		<header class="award-header">
			<h2 class="award-title">수상</h2>
			<p class="award-subtitle">총 12팀, 총 1200만원</p>
			<p class="award-subtitle award-subtitle--accent">SW중심대학사업단장상 수여</p>
		</header>


	<div style="width:904px; height:510px; background:#004F9F33; border-radius:16px; position:relative; overflow:hidden;">
		<div style="
			position:absolute;
			left:48px;
			top:51px;
			width:796px;
			height:425px;
			display:grid;
			grid-template-columns:398px 398px;
			grid-template-rows: 70px 70px 70px 70px 70px 70px;
			color:#fff;
			font-size:16px;
			font-weight:700;
			line-height:1.45;
			text-align:center;
		">
			<div style="display:flex; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			구분
			</div>
			<div style="display:flex; align-items:center; justify-content:center; rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			상금
			</div>

			<div style="display:flex; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			대상
			</div>
			<div style="display:flex; align-items:center; justify-content:center; rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			각 200만원(3팀)
			</div>

			<div style="display:flex; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			최우수상
			</div>
			<div style="display:flex; align-items:center; justify-content:center; rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			각 100만원(3팀)
			</div>

			<div style="display:flex; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			우수상
			</div>
			<div style="display:flex; align-items:center; justify-content:center; rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			각 50만원(6팀)
			</div>

			<div style="display:flex; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			
			</div>
			<div style="display:flex; align-items:center; justify-content:center; rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			
			</div>
			
			<div style="display:flex; background:#004F9F33; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65);">
			합계
			</div>
			<div style="display:flex; background:#004F9F33; align-items:center; justify-content:center; rgba(255,255,255,0.65);">
			1,200만원
			</div>


		</div>
	</div>



		<slot />
</div>
</SectionLayout>




<style>
	.award-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		color: #ffffff;
	}

	.award-header {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		margin-bottom: 42px;
	}

	.award-title {
		margin: 0;
		font-size: 48px;
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: -0.04em;
		color: #ffffff;
	}

	.award-subtitle {
		margin: 0;
		font-size: 18px;
		font-weight: 600;
		line-height: 1.35;
		color: #ffffff;
	}

	.award-subtitle--accent {
		font-weight: 500;
	}

	.pretitle,
	.title-line,
	.subtitle {
		margin: 0;
		font-family: Inter, system-ui, sans-serif;
	}

	.pretitle {
		font-size: 25px;
		font-weight: 800;
		line-height: 1.2;
		color: #ffffff;
	}

	.title-line {
		font-size: clamp(56px, 7vw, 70px);
		font-weight: 600;
		line-height: 1.1;
		color: #1566e8;
	}

	.subtitle {
		font-size: clamp(60px, 8vw, 85px);
		font-weight: 800;
		line-height: 1.05;
		color: #ffffff;
	}

	@media (max-width: 768px) {
		.award-header {
			margin-bottom: 28px;
			gap: 6px;
		}

		.award-title {
			font-size: 32px;
		}

		.award-subtitle {
			font-size: 15px;
		}
	}
</style>
