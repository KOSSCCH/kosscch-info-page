---
import SectionLayout from "./SectionLayout.astro";

interface Props {
	tagline?: string;
	sectionId?: string;
	sectionName?: string;
	pretitle?: string;
	titleLine?: string;
	subtitle?: string;
	sectionClass?: string;
}

const {
	sectionId = "competition",
	sectionName = "competition",
	sectionClass = "",
} = Astro.props;
---

<SectionLayout
	sectionId={sectionId}
	sectionName={sectionName}
	sectionClass={`competition-info ${sectionClass}`.trim()}
>
	<div class="competition-content">
		<h2 class="section-title">대회일정</h2>
		<p class="section-subtitle">주요 일정</p>

	<div style="width:680px; height:277px; background:#004F9F33; border-radius:16px; position:relative; overflow:hidden;">
		<div style="
			position:absolute;
			left:42px;
			top:45px;
			width:596px;
			height:188px;
			display:grid;
			grid-template-columns:172px 104px 173px 147px;
			grid-template-rows:62px 62px 64px;
			color:#fff;
			font-size:16px;
			font-weight:700;
			line-height:1.45;
			text-align:center;
		">
			<div style="display:flex; background-color:#004F9F33; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			6.1(월)~6.26(월)
			</div>
			<div style="display:flex; background-color:#004F9F33; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			7.5(월)
			</div>
			<div style="display:flex; background-color:#004F9F33; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			7.6(월)~8.9(월)
			</div>
			<div style="display:flex; background-color:#004F9F33; align-items:center; justify-content:center; border-bottom:1px solid rgba(255,255,255,0.65);">
			9.5(토)
			</div>

			<div style="display:flex; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			참가 접수
			</div>
			<div style="display:flex; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			예선 심사<br>및 발표
			</div>
			<div style="display:flex; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65); border-bottom:1px solid rgba(255,255,255,0.65);">
			개발
			</div>
			<div style="display:flex; align-items:center; justify-content:center; border-bottom:1px solid rgba(255,255,255,0.65);">
			본선 및 시상
			</div>

			<div style="display:flex; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65);">
			기획안 및 개발 로드맵<br>보고서 제출
			</div>
			<div style="display:flex; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65);">
			20개팀 선발
			</div>
			<div style="display:flex; align-items:center; justify-content:center; border-right:1px solid rgba(255,255,255,0.65);">
			팀별 프로젝트 구현<br>및 멘토링 진행
			</div>
			<div style="display:flex; align-items:center; justify-content:center;">
			발표 심사,<br>전시 및 시상
			</div>
		</div>
	</div>
		<p class="caption">* 상기 일정은 사정에 따라 변경될 수 있습니다.</p>

		<div class="final-section">
			<h2 class="final-title">본선 일정</h2>

			<div class="final-list">
				<div class="final-row">
					<div class="final-label">본선 일시</div>
					<div class="final-value">2026.9.5(토)</div>
				</div>

				<div class="final-row">
					<div class="final-label">본선 장소</div>
					<div class="final-value">국민대학교 콘서트홀</div>
				</div>
			</div>

			<p class="caption caption--final">* 본선 세부 일정은 본선 진출 팀들에 한해 추후 공지될 예정입니다.</p>
		</div>
	</div>




	
    <slot />
</SectionLayout>




<style>
	.competition-content {
		width: min(100%, 920px);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.section-title {
		margin: 0;
		color: #ffffff;
		font-size: 48px;
		font-weight: 800;
		line-height: 1.1;
		letter-spacing: -0.04em;
	}

	.section-subtitle {
		margin: 14px 0 18px;
		color: rgba(255, 255, 255, 0.92);
		font-size: 28px;
		font-weight: 700;
		line-height: 1.2;
	}

	.caption {
		margin: 12px 0 0;
		color: rgba(255, 255, 255, 0.62);
		font-size: 13px;
		line-height: 1.5;
		text-align: left;
		width: min(100%, 560px);
	}

	.final-section {
		margin-top: 40px;
		width: min(100%, 560px);
		text-align: center;
	}

	.final-title {
		margin: 0;
		color: #ffffff;
		font-size: 28px;
		font-weight: 800;
		line-height: 1.2;
	}

	.final-list {
		margin-top: 22px;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.final-row {
		display: grid;
		grid-template-columns: 112px minmax(0, 1fr);
		gap: 18px;
		align-items: center;
	}

	.final-label {
		color: #ffffff;
		font-size: 20px;
		font-weight: 800;
		line-height: 1.2;
		text-align: center;
	}

	.final-value {
		color: #ffffff;
		font-size: 20px;
		font-weight: 500;
		line-height: 1.2;
		text-align: center;
	}

	.caption--final {
		width: 100%;
		margin-top: 16px;
		text-align: left;
	}

	.pretitle,
	.title-line,
	.subtitle {
		margin: 0;
		font-family: Inter, system-ui, sans-serif;
	}

	.pretitle {
		font-size: 25px;
		font-weight: 800;
		line-height: 1.2;
		color: #ffffff;
	}

	.title-line {
		font-size: clamp(56px, 7vw, 70px);
		font-weight: 600;
		line-height: 1.1;
		color: #1566e8;
	}

	.subtitle {
		font-size: clamp(60px, 8vw, 85px);
		font-weight: 800;
		line-height: 1.05;
		color: #ffffff;
	}

	@media (max-width: 720px) {
		.competition-content {
			width: 100%;
		}

		.section-title {
			font-size: 34px;
		}

		.section-subtitle {
			font-size: 16px;
			margin-top: 12px;
		}

		.caption {
			width: 100%;
			font-size: 12px;
		}

		.final-section {
			width: 100%;
			margin-top: 40px;
		}

		.final-title {
			font-size: 24px;
		}

		.final-row {
			grid-template-columns: 1fr;
			gap: 6px;
		}

		.final-label,
		.final-value {
			font-size: 16px;
		}

		.caption--final {
			text-align: center;
		}
	}
</style>
