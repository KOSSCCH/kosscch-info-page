---
import HeroSection from "./sections/HeroSection.astro";
import AboutSection from "./sections/AboutSection.astro";
import ServiceSection from "./sections/ServiceSection.astro";
import ParticipationGuideSection from "./sections/ParticipationGuideSection.astro";
import ContactSection from "./sections/ContactSection.astro";
import homePageScriptUrl from "../../scripts/home-page.ts?url";
import CompetitionTitle from "./sections/CompetitionTitle.astro";
import CompetitionInfo from "./sections/CompetitionInfo.astro";
import CompetitionPlan from "./sections/CompetitionPlan.astro";
import CompetitionReward from "./sections/CompetitionReward.astro";

interface Props {
  logo?: string;
}

const { logo = "SSAMMU" } = Astro.props;
---

<section class="home-page">
  <link rel="stylesheet" href={new URL('./sections/sections.css', import.meta.url).href} />

  <main class="section-container">
    <CompetitionTitle />
    <AboutSection />
    <CompetitionInfo />
    <CompetitionPlan />
    <CompetitionReward />
    <ParticipationGuideSection />
    <ContactSection />


    <!-- <HeroSection /> -->
    <!-- <ServiceSection /> -->
  </main>
</section>

<script is:inline type="module" src={homePageScriptUrl}></script>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    scroll-behavior: auto;
    overscroll-behavior: none;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  :global(body) {
    margin: 0;
    background: #f7f7f8;
    color: #171717;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  :global(html::-webkit-scrollbar),
  :global(body::-webkit-scrollbar) {
    display: none;
  }

  :global(a) {
    color: inherit;
    text-decoration: none;
  }

  .home-page {
    min-height: 100vh;
    overflow-x: hidden;
  }

  .section-container {
    width: 100%;
  }
</style>
